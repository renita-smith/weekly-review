<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Weekly Review — Renita Smith</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css">
<style>
  *{box-sizing:border-box;margin:0;padding:0;}
  body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f5f4f0;color:#1a1a1a;padding:2rem;max-width:900px;margin:0 auto;}
  h1{font-size:22px;font-weight:500;margin-bottom:4px;}
  .subtitle{font-size:13px;color:#666;margin-bottom:1.5rem;}
  .section-title{font-size:11px;font-weight:500;color:#888;text-transform:uppercase;letter-spacing:0.06em;margin:0 0 10px;}
  .card{background:#fff;border:0.5px solid rgba(0,0,0,0.1);border-radius:12px;padding:1rem 1.25rem;margin-bottom:12px;}
  .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:1.5rem;}
  .grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:1.5rem;}
  .grid-5{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-bottom:1.5rem;}
  .metric{background:#f0efe9;border-radius:8px;padding:0.75rem 1rem;}
  .metric-label{font-size:11px;color:#888;margin-bottom:2px;}
  .metric-value{font-size:22px;font-weight:500;}
  .metric-value.danger{color:#a32d2d;}
  .domain-pill{display:inline-flex;align-items:center;font-size:12px;font-weight:500;padding:3px 10px;border-radius:20px;cursor:pointer;border:1.5px solid transparent;transition:all 0.15s;user-select:none;}
  .pill-rcbs{background:#EEEDFE;color:#3C3489;}
  .pill-rws{background:#E1F5EE;color:#085041;}
  .pill-sm{background:#FAECE7;color:#712B13;}
  .pill-mts{background:#FAEEDA;color:#633806;}
  .pill-eplc{background:#E6F1FB;color:#0C447C;}
  .pill-active-rcbs{border-color:#7F77DD;}
  .pill-active-rws{border-color:#1D9E75;}
  .pill-active-sm{border-color:#D85A30;}
  .pill-active-mts{border-color:#EF9F27;}
  .pill-active-eplc{border-color:#378ADD;}
  .domain-filter-bar{display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap;align-items:center;}
  .clear-filter{font-size:12px;color:#888;cursor:pointer;padding:3px 8px;}
  .project-row{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:0.5px solid rgba(0,0,0,0.08);transition:opacity 0.2s;}
  .project-row:last-of-type{border-bottom:none;}
  .project-name{flex:1;font-size:14px;}
  .star{font-size:16px;cursor:pointer;user-select:none;line-height:1;}
  .star-on{color:#EF9F27;}
  .star-off{color:#ccc;}
  .progress-wrap{padding:2px 0 8px 26px;}
  .progress-bar{height:4px;background:#f0efe9;border-radius:2px;}
  .progress-fill{height:4px;border-radius:2px;}
  .task-row{display:flex;align-items:flex-start;gap:10px;padding:8px 0;border-bottom:0.5px solid rgba(0,0,0,0.08);transition:opacity 0.2s;}
  .task-row:last-child{border-bottom:none;}
  .task-check{width:16px;height:16px;border:0.5px solid #bbb;border-radius:4px;margin-top:2px;flex-shrink:0;}
  .task-name{font-size:14px;margin:0 0 2px;}
  .task-due{font-size:12px;color:#888;margin:0;display:flex;align-items:center;gap:6px;}
  .note-row{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:0.5px solid rgba(0,0,0,0.08);}
  .note-row:last-child{border-bottom:none;}
  .note-title{flex:2;font-size:14px;}
  .note-select{flex:1;}
  .note-age{font-size:12px;color:#888;min-width:70px;text-align:right;}
  select{font-size:12px;padding:3px 6px;border-radius:8px;border:0.5px solid #ccc;background:#f5f4f0;color:#555;width:100%;}
  .dist-bar-wrap{display:flex;gap:3px;height:10px;border-radius:5px;overflow:hidden;margin-bottom:10px;}
  .dist-seg{height:100%;}
  .dist-legend{display:flex;flex-wrap:wrap;gap:10px;}
  .dist-item{display:flex;align-items:center;gap:5px;font-size:12px;color:#666;}
  .dist-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
  .habit-row{display:flex;align-items:center;gap:10px;padding:5px 0;}
  .habit-name{flex:1;font-size:13px;}
  .habit-score{display:flex;gap:4px;}
  .habit-dot{width:11px;height:11px;border-radius:50%;}
  .dot-done{background:#1D9E75;}
  .dot-miss{background:#f0efe9;border:0.5px solid #ccc;}
  .day-headers{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;margin-bottom:4px;}
  .day-header-label{font-size:10px;color:#888;text-align:center;}
  .cal-week{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;margin-bottom:8px;}
  .cal-day{background:#f5f4f0;border-radius:8px;padding:6px 4px;min-height:64px;}
  .cal-day-label{font-size:10px;font-weight:500;color:#888;text-align:center;margin-bottom:4px;}
  .cal-event{font-size:10px;padding:2px 4px;border-radius:4px;margin-bottom:2px;line-height:1.3;}
  .ev-sm{background:#FAECE7;color:#712B13;}
  .ev-rws{background:#E1F5EE;color:#085041;}
  .ev-eplc{background:#E6F1FB;color:#0C447C;}
  .ev-mts{background:#FAEEDA;color:#633806;}
  .ev-personal{background:#EEEDFE;color:#3C3489;}
  .week-divider{font-size:11px;font-weight:500;color:#888;margin:10px 0 6px;padding-bottom:4px;border-bottom:0.5px solid rgba(0,0,0,0.08);}
  .hidden{opacity:0.15;pointer-events:none;}
  .reflect-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:12px;}
  textarea{width:100%;font-size:13px;resize:none;border:0.5px solid #ccc;border-radius:8px;padding:8px 10px;background:#f5f4f0;color:#1a1a1a;font-family:inherit;line-height:1.5;}
  textarea:focus{outline:none;border-color:#888;}
  .btn{font-size:13px;padding:8px 16px;border-radius:8px;border:0.5px solid #bbb;background:#fff;cursor:pointer;color:#1a1a1a;transition:background 0.15s;}
  .btn:hover{background:#f0efe9;}
  .btn-full{width:100%;}
  .btn-primary{background:#1a1a1a;color:#fff;border-color:#1a1a1a;}
  .btn-primary:hover{background:#333;}
  .carried-row{display:flex;align-items:flex-start;gap:10px;padding:8px 0;border-bottom:0.5px solid rgba(0,0,0,0.08);}
  .carried-row:last-child{border-bottom:none;}
  .overdue-check{width:16px;height:16px;border:0.5px solid #a32d2d;border-radius:4px;margin-top:2px;flex-shrink:0;}
  .overdue-name{font-size:14px;color:#a32d2d;margin:0 0 2px;}
  .overdue-sub{font-size:12px;color:#888;margin:0;display:flex;align-items:center;gap:6px;}
  .header-row{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:1.5rem;}
  hr{border:none;border-top:0.5px solid rgba(0,0,0,0.08);margin:1.5rem 0;}
</style>
</head>
<body>

<div class="header-row">
  <div>
    <h1>Saturday review</h1>
    <p class="subtitle" id="weekLabel">Loading dates…</p>
  </div>
  <button class="btn">Plan ahead →</button>
</div>

<div class="grid-5">
  <div class="metric"><p class="metric-label">Active projects</p><p class="metric-value">11</p></div>
  <div class="metric"><p class="metric-label">Tasks · next 2 wks</p><p class="metric-value">14</p></div>
  <div class="metric"><p class="metric-label">Overdue tasks</p><p class="metric-value danger">2</p></div>
  <div class="metric"><p class="metric-label">Unprocessed notes</p><p class="metric-value">5</p></div>
  <div class="metric"><p class="metric-label">Habit avg this week</p><p class="metric-value">71%</p></div>
</div>

<p class="section-title">Domain attention — week ending <span id="weekEndLabel"></span></p>
<div class="card" style="margin-bottom:1.5rem;">
  <div class="dist-bar-wrap">
    <div class="dist-seg" style="width:18%;background:#7F77DD;"></div>
    <div class="dist-seg" style="width:27%;background:#1D9E75;"></div>
    <div class="dist-seg" style="width:22%;background:#D85A30;"></div>
    <div class="dist-seg" style="width:15%;background:#EF9F27;"></div>
    <div class="dist-seg" style="width:18%;background:#378ADD;"></div>
  </div>
  <div class="dist-legend">
    <div class="dist-item"><div class="dist-dot" style="background:#7F77DD;"></div>RCBS 18%</div>
    <div class="dist-item"><div class="dist-dot" style="background:#1D9E75;"></div>RWS 27%</div>
    <div class="dist-item"><div class="dist-dot" style="background:#D85A30;"></div>SM 22%</div>
    <div class="dist-item"><div class="dist-dot" style="background:#EF9F27;"></div>MTS 15%</div>
    <div class="dist-item"><div class="dist-dot" style="background:#378ADD;"></div>EPLC 18%</div>
  </div>
</div>

<p class="section-title">Two-week outlook — calendar</p>
<div class="card" style="margin-bottom:1.5rem;">
  <p class="week-divider" id="week1Label">Week 1</p>
  <div class="cal-week" id="week1">
    <div class="cal-day"><p class="cal-day-label">Sun</p></div>
    <div class="cal-day"><p class="cal-day-label">Mon</p><div class="cal-event ev-eplc">Curriculum mtg</div></div>
    <div class="cal-day"><p class="cal-day-label">Tue</p><div class="cal-event ev-rws">Client call</div></div>
    <div class="cal-day"><p class="cal-day-label">Wed</p><div class="cal-event ev-sm">Sent Miami</div></div>
    <div class="cal-day"><p class="cal-day-label">Thu</p><div class="cal-event ev-mts">MTS check-in</div></div>
    <div class="cal-day"><p class="cal-day-label">Fri</p></div>
    <div class="cal-day"><p class="cal-day-label">Sat</p><div class="cal-event ev-personal">Weekly review</div></div>
  </div>
  <p class="week-divider" id="week2Label">Week 2</p>
  <div class="cal-week" id="week2">
    <div class="cal-day"><p class="cal-day-label">Sun</p><div class="cal-event ev-sm">Sunday service</div></div>
    <div class="cal-day"><p class="cal-day-label">Mon</p></div>
    <div class="cal-day"><p class="cal-day-label">Tue</p><div class="cal-event ev-rws">Proposal due</div></div>
    <div class="cal-day"><p class="cal-day-label">Wed</p><div class="cal-event ev-eplc">PD session</div></div>
    <div class="cal-day"><p class="cal-day-label">Thu</p></div>
    <div class="cal-day"><p class="cal-day-label">Fri</p></div>
    <div class="cal-day"><p class="cal-day-label">Sat</p><div class="cal-event ev-personal">Weekly review</div></div>
  </div>
</div>

<p class="section-title">Filter by domain</p>
<div class="domain-filter-bar" id="filterBar">
  <span class="domain-pill pill-rcbs" data-domain="rcbs" onclick="toggleFilter('rcbs')">RCBS</span>
  <span class="domain-pill pill-rws" data-domain="rws" onclick="toggleFilter('rws')">RWS</span>
  <span class="domain-pill pill-sm" data-domain="sm" onclick="toggleFilter('sm')">SM</span>
  <span class="domain-pill pill-mts" data-domain="mts" onclick="toggleFilter('mts')">MTS</span>
  <span class="domain-pill pill-eplc" data-domain="eplc" onclick="toggleFilter('eplc')">EPLC</span>
  <span class="clear-filter" onclick="clearFilter()">Clear</span>
</div>

<div class="grid-2">
  <div>
    <p class="section-title">Active projects — set priorities</p>
    <div class="card">
      <div class="project-row" data-domain="rws">
        <span class="star star-on" onclick="toggleStar(this)">★</span>
        <span class="project-name">Dashboard side hustle build</span>
        <span class="domain-pill pill-rws" style="cursor:default;font-size:11px;padding:2px 8px;">RWS</span>
      </div>
      <div class="progress-wrap"><div class="progress-bar"><div class="progress-fill" style="width:60%;background:#1D9E75;"></div></div></div>
      <div class="project-row" data-domain="sm">
        <span class="star star-on" onclick="toggleStar(this)">★</span>
        <span class="project-name">dWell post-conference follow up</span>
        <span class="domain-pill pill-sm" style="cursor:default;font-size:11px;padding:2px 8px;">SM</span>
      </div>
      <div class="progress-wrap"><div class="progress-bar"><div class="progress-fill" style="width:80%;background:#D85A30;"></div></div></div>
      <div class="project-row" data-domain="sm">
        <span class="star star-off" onclick="toggleStar(this)">☆</span>
        <span class="project-name">Sent Miami curriculum — Range</span>
        <span class="domain-pill pill-sm" style="cursor:default;font-size:11px;padding:2px 8px;">SM</span>
      </div>
      <div class="progress-wrap"><div class="progress-bar"><div class="progress-fill" style="width:40%;background:#D85A30;"></div></div></div>
      <div class="project-row" data-domain="eplc">
        <span class="star star-off" onclick="toggleStar(this)">☆</span>
        <span class="project-name">EPLC classroom systems</span>
        <span class="domain-pill pill-eplc" style="cursor:default;font-size:11px;padding:2px 8px;">EPLC</span>
      </div>
      <div class="progress-wrap"><div class="progress-bar"><div class="progress-fill" style="width:20%;background:#378ADD;"></div></div></div>
      <div class="project-row" data-domain="rcbs">
        <span class="star star-off" onclick="toggleStar(this)">☆</span>
        <span class="project-name">Personal health reset</span>
        <span class="domain-pill pill-rcbs" style="cursor:default;font-size:11px;padding:2px 8px;">RCBS</span>
      </div>
      <div class="progress-wrap"><div class="progress-bar"><div class="progress-fill" style="width:30%;background:#7F77DD;"></div></div></div>
      <div class="project-row" data-domain="mts">
        <span class="star star-off" onclick="toggleStar(this)">☆</span>
        <span class="project-name">MTS Q3 deliverables</span>
        <span class="domain-pill pill-mts" style="cursor:default;font-size:11px;padding:2px 8px;">MTS</span>
      </div>
      <div class="progress-wrap" style="padding-bottom:0;"><div class="progress-bar"><div class="progress-fill" style="width:50%;background:#EF9F27;"></div></div></div>
    </div>
  </div>

  <div>
    <p class="section-title">Tasks — next two weeks</p>
    <div class="card">
      <div class="task-row" data-domain="sm">
        <div class="task-check"></div>
        <div style="flex:1;">
          <p class="task-name">Send speaker thank-you notes</p>
          <p class="task-due">Mon Jun 23 · <span class="domain-pill pill-sm" style="cursor:default;font-size:11px;padding:1px 7px;">SM</span></p>
        </div>
      </div>
      <div class="task-row" data-domain="rws">
        <div class="task-check"></div>
        <div style="flex:1;">
          <p class="task-name">Finalize first client proposal</p>
          <p class="task-due">Wed Jun 25 · <span class="domain-pill pill-rws" style="cursor:default;font-size:11px;padding:1px 7px;">RWS</span></p>
        </div>
      </div>
      <div class="task-row" data-domain="mts">
        <div class="task-check"></div>
        <div style="flex:1;">
          <p class="task-name">Review MTS deliverables</p>
          <p class="task-due">Thu Jun 26 · <span class="domain-pill pill-mts" style="cursor:default;font-size:11px;padding:1px 7px;">MTS</span></p>
        </div>
      </div>
      <div class="task-row" data-domain="eplc">
        <div class="task-check"></div>
        <div style="flex:1;">
          <p class="task-name">Set up classroom systems doc</p>
          <p class="task-due">Fri Jun 27 · <span class="domain-pill pill-eplc" style="cursor:default;font-size:11px;padding:1px 7px;">EPLC</span></p>
        </div>
      </div>
      <div class="task-row" data-domain="rws">
        <div class="task-check"></div>
        <div style="flex:1;">
          <p class="task-name">Submit dashboard proposal</p>
          <p class="task-due">Tue Jul 1 · <span class="domain-pill pill-rws" style="cursor:default;font-size:11px;padding:1px 7px;">RWS</span></p>
        </div>
      </div>
      <div class="task-row" data-domain="eplc">
        <div class="task-check"></div>
        <div style="flex:1;">
          <p class="task-name">Attend PD session</p>
          <p class="task-due">Wed Jul 2 · <span class="domain-pill pill-eplc" style="cursor:default;font-size:11px;padding:1px 7px;">EPLC</span></p>
        </div>
      </div>
      <div class="task-row" data-domain="rcbs">
        <div class="task-check"></div>
        <div style="flex:1;">
          <p class="task-name">Schedule annual physical</p>
          <p class="task-due">Jul 4 wk · <span class="domain-pill pill-rcbs" style="cursor:default;font-size:11px;padding:1px 7px;">RCBS</span></p>
        </div>
      </div>
    </div>
  </div>
</div>

<p class="section-title">Note inbox — process &amp; assign</p>
<div class="card" style="margin-bottom:1.5rem;">
  <p style="font-size:12px;font-weight:500;color:#888;margin-bottom:8px;">This week</p>
  <div class="note-row">
    <i class="ti ti-note" style="font-size:16px;color:#888;flex-shrink:0;"></i>
    <span class="note-title">Idea for apostolic base session 3 opening</span>
    <span class="note-select"><select><option>Assign domain…</option><option>RCBS</option><option>RWS</option><option>SM</option><option>MTS</option><option>EPLC</option></select></span>
    <span class="note-age">2 days ago</span>
  </div>
  <div class="note-row">
    <i class="ti ti-note" style="font-size:16px;color:#888;flex-shrink:0;"></i>
    <span class="note-title">Dashboard pricing tier thoughts</span>
    <span class="note-select"><select><option>Assign domain…</option><option>RCBS</option><option>RWS</option><option>SM</option><option>MTS</option><option>EPLC</option></select></span>
    <span class="note-age">4 days ago</span>
  </div>
  <p style="font-size:12px;font-weight:500;color:#888;margin:12px 0 8px;">Older</p>
  <div class="note-row">
    <i class="ti ti-note" style="font-size:16px;color:#888;flex-shrink:0;"></i>
    <span class="note-title">Parent communication framework idea</span>
    <span class="note-select"><select><option>Assign domain…</option><option>RCBS</option><option>RWS</option><option>SM</option><option>MTS</option><option>EPLC</option></select></span>
    <span class="note-age">12 days ago</span>
  </div>
</div>

<div class="grid-2" style="margin-bottom:1.5rem;">
  <div>
    <p class="section-title">Habit pulse — week ending <span id="habitWeekLabel"></span></p>
    <div class="card">
      <div class="habit-row"><span class="habit-name">Morning stretch</span><div class="habit-score"><div class="habit-dot dot-done"></div><div class="habit-dot dot-miss"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-miss"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-miss"></div></div></div>
      <div class="habit-row"><span class="habit-name">Daily bread</span><div class="habit-score"><div class="habit-dot dot-done"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-miss"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-done"></div></div></div>
      <div class="habit-row"><span class="habit-name">Prayer / quiet time</span><div class="habit-score"><div class="habit-dot dot-done"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-miss"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-done"></div></div></div>
      <div class="habit-row"><span class="habit-name">Highlight journaling</span><div class="habit-score"><div class="habit-dot dot-miss"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-miss"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-miss"></div><div class="habit-dot dot-miss"></div><div class="habit-dot dot-miss"></div></div></div>
      <div class="habit-row"><span class="habit-name">Make up bed</span><div class="habit-score"><div class="habit-dot dot-done"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-miss"></div><div class="habit-dot dot-miss"></div></div></div>
      <div class="habit-row"><span class="habit-name">Daily declaration</span><div class="habit-score"><div class="habit-dot dot-done"></div><div class="habit-dot dot-miss"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-miss"></div></div></div>
      <div class="habit-row"><span class="habit-name">Step count</span><div class="habit-score"><div class="habit-dot dot-miss"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-miss"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-miss"></div><div class="habit-dot dot-miss"></div></div></div>
      <div class="habit-row"><span class="habit-name">Exercise</span><div class="habit-score"><div class="habit-dot dot-done"></div><div class="habit-dot dot-miss"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-miss"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-miss"></div><div class="habit-dot dot-miss"></div></div></div>
      <div class="habit-row"><span class="habit-name">Next day prep</span><div class="habit-score"><div class="habit-dot dot-done"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-miss"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-done"></div><div class="habit-dot dot-miss"></div></div></div>
    </div>
  </div>
  <div>
    <p class="section-title">What didn't get done</p>
    <div class="card">
      <div class="carried-row">
        <div class="overdue-check"></div>
        <div style="flex:1;">
          <p class="overdue-name">Update MTS tracker</p>
          <p class="overdue-sub">Carried from last week · <span class="domain-pill pill-mts" style="cursor:default;font-size:11px;padding:1px 7px;">MTS</span></p>
        </div>
      </div>
      <div class="carried-row">
        <div class="overdue-check"></div>
        <div style="flex:1;">
          <p class="overdue-name">RCBS budget review</p>
          <p class="overdue-sub">Carried from last week · <span class="domain-pill pill-rcbs" style="cursor:default;font-size:11px;padding:1px 7px;">RCBS</span></p>
        </div>
      </div>
    </div>
  </div>
</div>

<p class="section-title">Weekly reflection</p>
<div class="card" style="margin-bottom:1.5rem;">
  <div class="reflect-grid">
    <div>
      <p style="font-size:12px;font-weight:500;color:#888;margin-bottom:6px;">What moved the needle?</p>
      <textarea rows="5" placeholder="Your biggest win this week…"></textarea>
    </div>
    <div>
      <p style="font-size:12px;font-weight:500;color:#888;margin-bottom:6px;">What didn't work?</p>
      <textarea rows="5" placeholder="What you'd do differently…"></textarea>
    </div>
    <div>
      <p style="font-size:12px;font-weight:500;color:#888;margin-bottom:6px;">What are you carrying into next week?</p>
      <textarea rows="5" placeholder="Intentions, posture, focus…"></textarea>
    </div>
  </div>
  <button class="btn btn-primary btn-full">Save reflection to Notion →</button>
</div>

<script>
  function formatDate(d) {
    return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }

  function getReviewDates() {
    const today = new Date();
    const day = today.getDay();
    const saturday = new Date(today);
    saturday.setDate(today.getDate() + ((6 - day + 7) % 7));
    const weekEnd = new Date(saturday);
    const week1Start = new Date(saturday);
    week1Start.setDate(saturday.getDate() + 1);
    const week1End = new Date(week1Start);
    week1End.setDate(week1Start.getDate() + 6);
    const week2Start = new Date(week1End);
    week2Start.setDate(week1End.getDate() + 1);
    const week2End = new Date(week2Start);
    week2End.setDate(week2Start.getDate() + 6);
    return { weekEnd, week1Start, week1End, week2Start, week2End };
  }

  const dates = getReviewDates();
  document.getElementById('weekLabel').textContent =
    'Week ending ' + formatDate(dates.weekEnd) + ' · Looking ahead to ' + formatDate(dates.week2End);
  document.getElementById('weekEndLabel').textContent = formatDate(dates.weekEnd);
  document.getElementById('habitWeekLabel').textContent = formatDate(dates.weekEnd);
  document.getElementById('week1Label').textContent =
    'Week 1 · ' + formatDate(dates.week1Start) + ' – ' + formatDate(dates.week1End);
  document.getElementById('week2Label').textContent =
    'Week 2 · ' + formatDate(dates.week2Start) + ' – ' + formatDate(dates.week2End);

  let activeFilter = null;

  function toggleFilter(domain) {
    if (activeFilter === domain) { clearFilter(); return; }
    activeFilter = domain;
    document.querySelectorAll('#filterBar .domain-pill').forEach(p => {
      p.classList.remove('pill-active-rcbs','pill-active-rws','pill-active-sm','pill-active-mts','pill-active-eplc');
      if (p.dataset.domain === domain) p.classList.add('pill-active-' + domain);
    });
    document.querySelectorAll('.project-row[data-domain], .task-row[data-domain]').forEach(row => {
      const isMatch = row.dataset.domain === domain;
      row.classList.toggle('hidden', !isMatch);
      const next = row.nextElementSibling;
      if (next && next.classList.contains('progress-wrap')) next.classList.toggle('hidden', !isMatch);
    });
  }

  function clearFilter() {
    activeFilter = null;
    document.querySelectorAll('#filterBar .domain-pill').forEach(p => {
      p.classList.remove('pill-active-rcbs','pill-active-rws','pill-active-sm','pill-active-mts','pill-active-eplc');
    });
    document.querySelectorAll('.project-row[data-domain], .task-row[data-domain], .progress-wrap').forEach(r => {
      r.classList.remove('hidden');
    });
  }

  function toggleStar(el) {
    const on = el.classList.contains('star-on');
    el.classList.toggle('star-on', !on);
    el.classList.toggle('star-off', on);
    el.textContent = on ? '☆' : '★';
  }
</script>
</body>
</html>
